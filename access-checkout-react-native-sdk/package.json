{
  "name": "@worldpay/access-worldpay-checkout-react-native-sdk",
  "version": "4.0.2",
  "description": "Worldpay Access Checkout SDK for ReactNative",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Worldpay/access-checkout-react-native.git"
  },
  "author": "Worldpay",
  "license": "ISC",
  "scripts": {
    "prepare": "bob build",
    "typescript": "tsc --noEmit true",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "lint:fix": "eslint --fix \"**/*.{js,ts,tsx}\"",
    "format": "prettier '{src,test}/**/*.{ts,tsx}' --write",
    "test": "npm run typescript && jest --clearCache && jest --coverage --verbose"
  },
  "source": "./src/index.tsx",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index",
  "types": "./lib/typescript/commonjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "default": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios/AccessCheckoutReactNative",
    "access-checkout-react-native-sdk.podspec",
    "CHANGELOG.md",
    "README.md",
    "worldpay_logo.png",
    "*.podspec",
    "!ios/Pods",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!android/src/androidTest",
    "!android/**/*Tests",
    "!**/test",
    "!**/.*"
  ],
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.3",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.85.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.84",
    "@types/react": "^19.2.14",
    "@types/react-test-renderer": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^30.4.1",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "jest": "^29.7.0",
    "jest-html-reporter": "^4.4.0",
    "jest-junit": "^17.0.0",
    "prettier": "^3.6.2",
    "react": "19.2.3",
    "react-native": "^0.86.0",
    "react-native-builder-bob": "^0.41.0",
    "react-test-renderer": "19.2.3",
    "ts-jest": "^29.4.11",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "react": ">=19.2.3",
    "react-native": ">=0.86.0"
  },
  "engines": {
    "node": ">=22"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs"
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  }
}
